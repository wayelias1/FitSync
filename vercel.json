{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    { "source": "/(.*)", "destination": "/" },
    { "source": "/api", "destination": "https://fitsync-d1x0.onrender.com/" },
    { "source": "/signup", "destination": "https://fitsync-d1x0.onrender.com/" },
    { "source": "/Login", "destination": "https://fitsync-d1x0.onrender.com/" },
    { "source": "/user", "destination": "https://fitsync-d1x0.onrender.com/"}
  ]
}
